{
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist/Kalman/browser" }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://kalman-server.onrender.com/api/$1"
    },
    { "source": "/((?!.*\\.).*)", "destination": "/index.html" }
  ]
}
